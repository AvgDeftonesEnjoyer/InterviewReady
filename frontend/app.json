{
  "expo": {
    "name": "InterviewReady",
    "slug": "interview-ready",
    "scheme": "interviewready",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.interviewready.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0f1a"
      },
      "package": "com.interviewready.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
